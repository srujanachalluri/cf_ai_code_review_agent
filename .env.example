# ============================================================
# .env.example  —  SAFE TO COMMIT. No real values here.
# ------------------------------------------------------------
# Copy this file to .env.local and fill in your real values.
# NEVER commit .env or .env.local to GitHub.
# ============================================================

# Cloudflare (get from dash.cloudflare.com)
CLOUDFLARE_ACCOUNT_ID=your_account_id_here
CLOUDFLARE_API_TOKEN=your_api_token_here

# Optional: external LLM for richer analysis
ANTHROPIC_API_KEY=your_anthropic_key_here

# App settings
NODE_ENV=development
LOG_LEVEL=debug
